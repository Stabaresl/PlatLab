# Normaliza automáticamente todo archivo de texto a LF en el repo
* text=auto eol=lf

# Forzar LF explícito en tipos de archivo clave
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
*.env* text eol=lf
Dockerfile text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binarios: no tocar nunca
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.sqlite3 binary
*.zip binary
